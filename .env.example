# Copy to `.env` and adjust. `.env` is git-ignored.
# NeuralForge-X runs fully locally; these only tune behaviour.

# Cap the rayon worker pool (defaults to physical core count).
# RAYON_NUM_THREADS=16

# Observability (Phase 7) — OpenTelemetry collector endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=neuralforge-x

# Logging verbosity for the Rust layer (error|warn|info|debug|trace).
# RUST_LOG=info
